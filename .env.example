# ============================================================
# Invoice Checker — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/invoice_checker

# --- Encryption (required) ---
# Used to encrypt all AI provider keys (OpenAI, Anthropic, Gemini) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENAI_ENCRYPTION_KEY=your_64_hex_char_key_here

# --- Initial admin account (used only on first run, when DB is empty) ---
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change_me_immediately
ADMIN_NAME=Admin

# --- API server ---
PORT=8080
NODE_ENV=development

# --- Session security (required in production) ---
SESSION_SECRET=change_me_to_a_long_random_string

# --- File storage ---
# By default, files are stored locally in ./uploads (no cloud account needed).
# To change the local upload directory:
# UPLOADS_PATH=./uploads

# To use Google Cloud Storage instead (for production deployments),
# set DEFAULT_OBJECT_STORAGE_BUCKET_ID and the app will switch automatically:
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-gcs-bucket-name
# PRIVATE_OBJECT_DIR=private
# PUBLIC_OBJECT_SEARCH_PATHS=public
